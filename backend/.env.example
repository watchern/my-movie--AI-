# 应用配置
APP_DEBUG = true

[APP]
DEFAULT_TIMEZONE = Asia/Shanghai

# 数据库配置
[DATABASE]
# 使用 mysql 或 sqlite
database.type = mysql
database.hostname = 127.0.0.1
database.database = moive_app
database.username = root
database.password =
database.hostport = 3306
database.charset = utf8mb4

# SQLite配置（仅在 database.type = sqlite 时有效）
# database.sqlite_path = ../database/database.sqlite

# JWT配置
[JWT]
JWT_SECRET = your-secret-key-change-in-production
JWT_EXPIRE = 604800  # 7天
JWT_REFRESH_EXPIRE = 2592000  # 30天

# 管理端配置
[ADMIN]
ADMIN_TOKEN_EXPIRE = 86400  # 24小时

# 缓存配置（可选，使用Redis时配置）
[CACHE]
cache.redis_host = 127.0.0.1
cache.redis_port = 6379
cache.redis_password =
cache.redis_select = 0
cache.redis_prefix = tp_
