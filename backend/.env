# 应用配置
APP_DEBUG = true

[APP]
DEFAULT_TIMEZONE = Asia/Shanghai

# 数据库配置
[DATABASE]
database.type = sqlite
database.sqlite_path = ../database/database.sqlite

# JWT配置
[JWT]
JWT_SECRET = your-secret-key-change-in-production
JWT_EXPIRE = 604800
JWT_REFRESH_EXPIRE = 2592000

# 管理端配置
[ADMIN]
ADMIN_TOKEN_EXPIRE = 86400