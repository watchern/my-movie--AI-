# 应用配置
APP_DEBUG=true
APP_TRACE=true

# 应用时区
DEFAULT_TIMEZONE=Asia/Shanghai

# 数据库配置 - 使用SQLite
DATABASE_TYPE=sqlite
DATABASE_SQLITE_PATH=c:/Users/Administrator/Desktop/moive-app/database/database.sqlite

# JWT配置 - 7天过期，30天刷新过期
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRE=604800
JWT_REFRESH_EXPIRE=2592000

# 管理端配置 - 24小时过期
ADMIN_TOKEN_EXPIRE=86400

# 缓存配置可选值: file, redis - 默认使用文件缓存
CACHE_DEFAULT=file
CACHE_REDIS_HOST=127.0.0.1
CACHE_REDIS_PORT=6379
CACHE_REDIS_PASSWORD=
CACHE_REDIS_SELECT=0
CACHE_REDIS_PREFIX=tp_